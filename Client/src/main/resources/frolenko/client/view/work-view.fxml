<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="frolenko.client.controller.WorkController"
            style="-fx-background-color: #fff5f7;">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT"
              style="-fx-padding: 10 15; -fx-background-color: #fce4ec; -fx-border-color: #f8bbd0; -fx-border-width: 0 0 1 0;">
            <Label fx:id="titleLabel" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #880e4f;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Back" onAction="#onBack"
                    style="-fx-background-color: #f06292; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 5 12;"/>
        </HBox>
    </top>

    <center>
        <AnchorPane fx:id="canvasContainer" style="-fx-background-color: #e0e0e0;"/>
    </center>

</BorderPane>