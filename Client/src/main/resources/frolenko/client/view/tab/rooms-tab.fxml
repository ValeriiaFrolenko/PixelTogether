<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" style="-fx-padding: 15;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="frolenko.client.controller.tab.RoomsTabController">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <TextField fx:id="privateCodeField" promptText="Private room code" HBox.hgrow="ALWAYS"/>
        <Button text="Join Private" onAction="#onJoinPrivate"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="createRoomButton" text="Create Room" onAction="#onCreateRoom"
                visible="false" managed="false"/>
        <Button text="Refresh" onAction="#onRefreshRooms"/>
    </HBox>

    <ListView fx:id="roomListView" VBox.vgrow="ALWAYS"/>

    <Button text="Join" onAction="#onJoinPublic" maxWidth="Infinity"/>

</VBox>
