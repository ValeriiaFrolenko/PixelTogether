<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: #fff5f7; -fx-background: #fff5f7;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="frolenko.client.controller.tab.GalleryTabController">

    <VBox spacing="15" style="-fx-padding: 20; -fx-background-color: #fff5f7;" alignment="TOP_CENTER">

        <HBox spacing="15" alignment="CENTER">
            <TextField fx:id="titleFilter" promptText="Filter by title" prefWidth="200" onKeyReleased="#onFilterChanged"
                       style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;"/>
            <TextField fx:id="authorFilter" promptText="Filter by author" prefWidth="200" onKeyReleased="#onFilterChanged"
                       style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;"/>
            <Button fx:id="refreshButton" text="Refresh" onAction="#onRefresh"
                    style="-fx-background-color: #ffffff; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-padding: 5 12;"/>
        </HBox>

        <ListView fx:id="galleryListView" prefHeight="300" maxWidth="600"
                  style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;">
            <placeholder>
                <Label text="Gallery is empty" style="-fx-text-fill: #880e4f;"/>
            </placeholder>
        </ListView>

        <Button fx:id="viewButton" text="View" onAction="#onViewWork" prefWidth="200"
                style="-fx-background-color: #f06292; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 8 16;"/>

    </VBox>
</ScrollPane>
