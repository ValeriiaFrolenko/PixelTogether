<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: #fff5f7; -fx-background: #fff5f7;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="frolenko.client.controller.tab.AccountTabController">

    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #fff5f7;" alignment="TOP_CENTER">

        <VBox fx:id="guestPane" spacing="12" maxWidth="300" alignment="TOP_CENTER"
              style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-border-color: #f8bbd0; -fx-border-radius: 8; -fx-background-radius: 8;">
            <Label text="Authorization" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #880e4f;"/>
            <TextField fx:id="usernameField" promptText="Username"
                       style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;"/>
            <PasswordField fx:id="passwordField" promptText="Password"
                           style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;"/>
            <HBox spacing="10" alignment="CENTER">
                <Button fx:id="loginButton" text="Login" onAction="#onLogin" prefWidth="100"
                        style="-fx-background-color: #f06292; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 6 12;"/>
                <Button fx:id="registerButton" text="Register" onAction="#onRegister" prefWidth="100"
                        style="-fx-background-color: #fce4ec; -fx-border-color: #f06292; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-font-weight: bold; -fx-padding: 6 12;"/>
            </HBox>
            <Label fx:id="authErrorLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 11;"/>
        </VBox>

        <VBox fx:id="loggedInPane" spacing="15" maxWidth="600" visible="false" managed="false" alignment="TOP_CENTER">

            <HBox spacing="15" alignment="CENTER_LEFT"
                  style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #f8bbd0; -fx-border-radius: 8; -fx-background-radius: 8;">
                <Label text="Logged in as:" style="-fx-text-fill: #666666; -fx-font-size: 12;"/>
                <Label fx:id="usernameLabel" style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #880e4f;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Logout" onAction="#onLogout"
                        style="-fx-background-color: #ffffff; -fx-border-color: #f06292; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-padding: 6 12;"/>
            </HBox>

            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="My Works" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #880e4f;"/>
                    <Button text="Refresh" onAction="#onRefreshMyWorks"
                            style="-fx-background-color: #ffffff; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-padding: 3 8;"/>
                </HBox>
                <ListView fx:id="myWorksListView" prefHeight="150"
                          style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                    <placeholder>
                        <Label text="No saved works" style="-fx-text-fill: #880e4f;"/>
                    </placeholder>
                </ListView>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="View" onAction="#onViewMyWork"
                            style="-fx-background-color: #fce4ec; -fx-border-color: #f06292; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-font-weight: bold; -fx-padding: 5 12;"/>
                    <Button text="Delete" onAction="#onDeleteMyWork"
                            style="-fx-background-color: #ffffff; -fx-border-color: #f06292; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-padding: 5 12;"/>
                </HBox>
            </VBox>

            <VBox spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="My Rooms" style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #880e4f;"/>
                    <Button text="Refresh" onAction="#onRefreshMyRooms"
                            style="-fx-background-color: #ffffff; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-padding: 3 8;"/>
                </HBox>
                <ListView fx:id="myRoomsListView" prefHeight="150"
                          style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;">
                    <placeholder>
                        <Label text="No active rooms" style="-fx-text-fill: #880e4f;"/>
                    </placeholder>
                </ListView>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Join" onAction="#onJoinMyRoom"
                            style="-fx-background-color: #f06292; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 5 12;"/>
                    <Button text="Copy Code" onAction="#onCopyCode"
                            style="-fx-background-color: #fce4ec; -fx-border-color: #f06292; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-font-weight: bold; -fx-padding: 5 12;"/>
                </HBox>
            </VBox>

        </VBox>

    </VBox>
</ScrollPane>
