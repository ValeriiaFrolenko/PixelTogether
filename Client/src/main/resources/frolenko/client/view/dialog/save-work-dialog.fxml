<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" style="-fx-padding: 25; -fx-background-color: #fff5f7;" maxWidth="350" prefWidth="350" alignment="TOP_LEFT"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="frolenko.client.controller.dialog.SaveWorkDialogController">

    <Label text="Save Work" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #880e4f; -fx-padding: 0 0 10 0;"/>

    <Label text="Title" style="-fx-text-fill: #555555; -fx-font-weight: bold; -fx-font-size: 12;"/>
    <TextField fx:id="titleField" promptText="Work title" maxWidth="300"
               style="-fx-background-radius: 4; -fx-border-color: #f8bbd0; -fx-border-radius: 4; -fx-background-color: #ffffff;"/>

    <CheckBox fx:id="publicCheckBox" text="Public" style="-fx-text-fill: #333333; -fx-padding: 5 0 5 0;"/>

    <Label fx:id="errorLabel" style="-fx-text-fill: #d32f2f; -fx-font-size: 11;"/>

    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancel" onAction="#onCancel"
                style="-fx-background-color: #ffffff; -fx-border-color: #f06292; -fx-border-radius: 4; -fx-background-radius: 4; -fx-text-fill: #880e4f; -fx-padding: 6 14;"/>
        <Button fx:id="saveButton" text="Save" onAction="#onSave" defaultButton="true"
                style="-fx-background-color: #f06292; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 4; -fx-padding: 6 14;"/>
    </HBox>

</VBox>