<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            style="-fx-background-color: #fff5f7; -fx-background: #fff5f7;"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="frolenko.client.controller.MainController">

    <stylesheets>
        <URL value="@styles.css"/>
    </stylesheets>

    <VBox style="-fx-background-color: #fff5f7;" minHeight="400" minWidth="600">

        <Label fx:id="serverBanner" text="Server unavailable" managed="false" visible="false"
               maxWidth="Infinity"
               style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-padding: 8; -fx-font-weight: bold; -fx-alignment: CENTER;"/>

        <TabPane VBox.vgrow="ALWAYS" tabClosingPolicy="UNAVAILABLE" styleClass="custom-tab-pane">
            <Tab text="Rooms">
                <fx:include source="tab/rooms-tab.fxml"/>
            </Tab>
            <Tab text="Gallery">
                <fx:include source="tab/gallery-tab.fxml"/>
            </Tab>
            <Tab text="Account">
                <fx:include source="tab/account-tab.fxml"/>
            </Tab>
        </TabPane>

    </VBox>
</ScrollPane>
